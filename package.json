{
  "name": "acuity-health-website",
  "version": "3.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "vercel-build": "if [ \"$VERCEL_ENV\" = \"production\" ]; then bunx prisma migrate deploy; fi && prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write --ignore-unknown . && prisma format",
    "format:check": "bun scripts/check-format-changed.mjs",
    "check": "bun run prisma:validate && bun run lint && bun run typecheck && bun test",
    "ci": "bun run check && bun run build",
    "test": "bun test",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed:abita-offices": "bun scripts/seed-abita-new-offices.mjs",
    "seed:abita-scoped-users": "bun scripts/seed-abita-scoped-users.mjs"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@telnyx/webrtc": "^2.26.4",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3"
  }
}
