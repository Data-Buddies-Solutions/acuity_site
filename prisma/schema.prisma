generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String                   @id @default(cuid())
  name                       String
  email                      String                   @unique
  emailVerified              Boolean                  @default(false)
  image                      String?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  accounts                   Account[]
  callCenterNotes            CallCenterNote[]
  callCenterPresence         CallCenterPresence[]
  callCenterQueueMemberships CallCenterQueueMember[]
  callCenterAgentSessions    CallCenterAgentSession[]
  assignedCallCenterTasks    CallCenterTask[]         @relation("CallCenterTaskAssignee")
  resolvedCallCenterTasks    CallCenterTask[]         @relation("CallCenterTaskResolver")
  callCenterEvents           CallCenterEvent[]        @relation("CallCenterEventActor")
  memberships                PracticeMembership[]
  sessions                   Session[]
  smsConversationReads       SmsConversationRead[]
  smsMessages                SmsMessage[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum PracticeMembershipRole {
  OWNER
  ADMIN
  STAFF
}

enum PracticeMembershipLocationScope {
  ALL
  SELECTED
}

enum PracticeOnboardingStatus {
  WEBSITE_PENDING
  BASICS_PENDING
  PROVIDERS_PENDING
  INSURANCE_PENDING
  KNOWLEDGE_PENDING
  READY_TO_LAUNCH
  LIVE
}

enum PracticeType {
  OPHTHALMOLOGY
  OPTOMETRY
  MIXED
  OTHER
}

enum PracticeAgentStatus {
  SETUP
  ACTIVE
  PAUSED
  ERROR
}

enum AgentCallStatus {
  IN_PROGRESS
  COMPLETED
  ESCALATED
  FAILED
  ABANDONED
}

enum AgentCallEvaluationBucket {
  GOLDEN
  BAD
}

enum AgentTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CLOSED_NO_ACTION
}

enum AgentTaskCategory {
  BILLING
  APPOINTMENTS
  DOCUMENTATION
  OTHER
}

enum AgentTaskPriority {
  HIGH_PRIORITY
  NORMAL
  NON_URGENT
}

enum AgentTaskSource {
  AGENT
}

enum LiveKitWebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum UsageCostCategory {
  LLM_INPUT
  LLM_CACHED_INPUT
  LLM_OUTPUT
  SPEECH_TO_TEXT
  TEXT_TO_SPEECH
  TELEPHONY
  REVIEW
  OTHER
}

enum CallCenterProvider {
  TELNYX
}

enum CallCenterSessionDirection {
  INBOUND
  OUTBOUND
  INTERNAL
  UNKNOWN
}

enum CallCenterSessionStatus {
  RINGING
  ACTIVE
  COMPLETED
  MISSED
  VOICEMAIL
  FAILED
}

enum CallCenterPresenceStatus {
  AVAILABLE
  BUSY
  OFFLINE
  PAUSED
}

enum CallCenterQueueStatus {
  RINGING
  WAITING
  ASSIGNED
  ACTIVE
  VOICEMAIL
  COMPLETED
  ABANDONED
}

enum CallCenterRingAttemptStatus {
  DIALING
  RINGING
  ANSWERED
  BRIDGED
  CANCELED
  NO_ANSWER
  FAILED
}

enum CallCenterNoteDisposition {
  RESOLVED
  CALLBACK_NEEDED
  FOLLOW_UP_REQUIRED
  WRONG_NUMBER
  OTHER
}

enum CallCenterQueueMemberRole {
  AGENT
  SUPERVISOR
}

enum CallCenterRoutingMode {
  LEGACY
  SHADOW
  ACTIVE
}

enum CallCenterAgentPresence {
  AVAILABLE
  PAUSED
  BUSY
  WRAP_UP
  OFFLINE
}

enum CallCenterAgentConnectionState {
  CONNECTING
  READY
  ERROR
  CLOSED
}

enum CallCenterCallDirection {
  INBOUND
  OUTBOUND
}

enum CallCenterCallStatus {
  RECEIVED
  QUEUED
  RINGING
  CONNECTED
  WRAP_UP
  COMPLETED
  VOICEMAIL
  ABANDONED
  FAILED
}

enum CallCenterLegKind {
  CUSTOMER
  AGENT
}

enum CallCenterLegStatus {
  CREATED
  DIALING
  RINGING
  ANSWERED
  BRIDGED
  ENDED
  FAILED
}

enum CallCenterTaskKind {
  MISSED_CALL
  VOICEMAIL
  CALLBACK
  FOLLOW_UP
}

enum CallCenterTaskStatus {
  OPEN
  RESOLVED
}

enum ProviderWebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  IGNORED
  FAILED
}

enum CallCenterCommandType {
  ANSWER_CUSTOMER
  START_RINGBACK
  DIAL_AGENT
  STOP_PLAYBACK
  BRIDGE_LEGS
  HANGUP_LEG
  PLAY_VOICEMAIL_GREETING
  START_RECORDING
}

enum CallCenterCommandStatus {
  PENDING
  SENDING
  SENT
  CONFIRMED
  FAILED
}

enum CallCenterEventAggregateType {
  CALL
  AGENT_SESSION
  TASK
  CONFIGURATION
}

enum WebsiteScanStatus {
  SUCCESS
  FAILED
}

enum KnowledgeDocumentType {
  KNOWLEDGE_BASE
}

enum KnowledgeDocumentStatus {
  ACTIVE
  ARCHIVED
}

enum KnowledgeDocumentRevisionSource {
  ADMIN
  PRACTICE
  IMPORT
}

enum KnowledgeDocumentRevisionStatus {
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

enum InsuranceRuleSetStatus {
  ACTIVE
  ARCHIVED
}

enum InsuranceRuleRevisionSource {
  ADMIN
  PRACTICE
  IMPORT
}

enum InsuranceRuleRevisionStatus {
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

enum AdminAlertType {
  KNOWLEDGE_BASE_EDITED
  INSURANCE_RULES_EDITED
}

enum AdminAlertStatus {
  UNREAD
  REVIEWING
  RESOLVED
}

enum SmsConversationStatus {
  OPEN
  CLOSED
}

enum SmsMessageDirection {
  INBOUND
  OUTBOUND
}

enum SmsMessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  RECEIVED
}

model Practice {
  id                       String                      @id @default(cuid())
  name                     String
  websiteUrl               String?
  brandLogoUrl             String?
  brandLogoAlt             String?
  brandMarkUrl             String?
  brandPrimaryColor        String?
  brandAccentColor         String?
  onboardingStatus         PracticeOnboardingStatus    @default(WEBSITE_PENDING)
  practiceType             PracticeType                @default(OTHER)
  launchReadyAt            DateTime?
  launchedAt               DateTime?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  callEvaluationLabels     AgentCallEvaluationLabel[]
  agentCalls               AgentCall[]
  agentTasks               AgentTask[]
  agents                   PracticeAgent[]
  callCenterAgentSeats     CallCenterAgentSeat[]
  callCenterMissed         CallCenterMissedCall[]
  callCenterNotes          CallCenterNote[]
  callCenterQueueItems     CallCenterQueueItem[]
  callCenterSessions       CallCenterSession[]
  callCenterSettings       PracticeCallCenterSettings?
  callCenterVoicemails     CallCenterVoicemail[]
  callCenterQueues         CallCenterQueue[]
  callCenterNumbers        CallCenterNumber[]
  callCenterEndpoints      CallCenterEndpoint[]
  callCenterAgentSessions  CallCenterAgentSession[]
  canonicalCallCenterCalls CallCenterCall[]
  callCenterTasks          CallCenterTask[]
  callCenterEvents         CallCenterEvent[]
  callCenterCommands       CallCenterCommand[]
  costLineItems            UsageCostLineItem[]
  adminAlerts              AdminAlert[]
  insuranceCrosswalk       PracticeInsuranceCrosswalk?
  insuranceRuleSets        PracticeInsuranceRuleSet[]
  knowledgeBase            PracticeKnowledgeBase?
  knowledgeDocuments       PracticeKnowledgeDocument[]
  locations                PracticeLocation[]
  memberships              PracticeMembership[]
  phoneNumbers             PracticePhoneNumber[]
  providers                PracticeProvider[]
  smsConversations         SmsConversation[]
  websiteScans             PracticeWebsiteScan[]

  @@map("practice")
}

model PracticeAgent {
  id              String              @id @default(cuid())
  practiceId      String
  name            String
  status          PracticeAgentStatus @default(SETUP)
  llmModel        String?
  voiceProvider   String?
  voiceName       String?
  configVersion   String?
  lastHeartbeatAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  calls           AgentCall[]
  practice        Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([status])
  @@map("practice_agent")
}

model PracticePhoneNumber {
  id               String            @id @default(cuid())
  practiceId       String
  locationId       String?
  phoneNumber      String            @unique
  label            String?
  isPrimary        Boolean           @default(false)
  smsEnabled       Boolean           @default(false)
  telnyxCampaignId String?
  telnyxSmsStatus  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  location         PracticeLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice         Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  smsConversations SmsConversation[]
  smsOptOuts       SmsOptOut[]
  callCenterNumber CallCenterNumber?

  @@index([practiceId])
  @@index([locationId])
  @@index([smsEnabled])
  @@map("practice_phone_number")
}

model AgentCall {
  id                   String                     @id @default(cuid())
  practiceId           String
  locationId           String?
  agentId              String?
  callId               String                     @unique
  callerPhone          String
  officePhone          String
  status               AgentCallStatus            @default(COMPLETED)
  startedAt            DateTime                   @default(now())
  endedAt              DateTime?
  durationSec          Int                        @default(0)
  transferred          Boolean                    @default(false)
  bookedAppointment    Boolean                    @default(false)
  confirmedAppointment Boolean                    @default(false)
  cancelledAppointment Boolean                    @default(false)
  llmModel             String?
  fallbackUsed         Boolean                    @default(false)
  totalTurns           Int                        @default(0)
  inputTokens          Int                        @default(0)
  outputTokens         Int                        @default(0)
  cachedTokens         Int                        @default(0)
  ttsChars             Int                        @default(0)
  toolCalls            Int                        @default(0)
  toolErrors           Int                        @default(0)
  avgTtft              Float                      @default(0)
  avgTtsttfb           Float                      @default(0)
  cacheHitRate         Float                      @default(0)
  peakContext          Int                        @default(0)
  avgTokensPerSec      Float                      @default(0)
  interruptionCount    Int                        @default(0)
  estimatedCostMicros  Int                        @default(0)
  outcomeSummary       String?
  latencyValues        Json                       @default("{}")
  data                 Json?
  audioData            Bytes?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  agent                PracticeAgent?             @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentTasks           AgentTask[]
  callCenterMissed     CallCenterMissedCall[]
  callCenterSessions   CallCenterSession[]
  costLineItems        UsageCostLineItem[]
  evaluationLabels     AgentCallEvaluationLabel[]
  liveKitWebhookEvents LiveKitWebhookEvent[]
  location             PracticeLocation?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice             Practice                   @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, startedAt])
  @@index([practiceId, status])
  @@index([locationId])
  @@index([agentId])
  @@index([callerPhone])
  @@index([officePhone])
  @@map("agent_call")
}

model AgentTask {
  id                 String            @id @default(cuid())
  practiceId         String
  locationId         String?
  agentCallId        String?
  callId             String
  idempotencyKey     String
  status             AgentTaskStatus   @default(OPEN)
  category           AgentTaskCategory
  priority           AgentTaskPriority @default(NORMAL)
  officeKey          String?
  officePhone        String
  inboundOfficePhone String?
  summary            String
  message            String
  callerPhone        String
  patientId          String?
  patientName        String?
  patientDob         String?
  source             AgentTaskSource   @default(AGENT)
  payload            Json              @default("{}")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  completedAt        DateTime?
  agentCall          AgentCall?        @relation(fields: [agentCallId], references: [id], onDelete: SetNull)
  location           PracticeLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice           Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([practiceId, idempotencyKey])
  @@index([practiceId, status, category, createdAt])
  @@index([practiceId, locationId, status, createdAt])
  @@index([practiceId, status, priority, createdAt])
  @@index([agentCallId])
  @@index([callId])
  @@map("agent_task")
}

model LiveKitWebhookEvent {
  id                   String                         @id @default(cuid())
  eventId              String                         @unique
  eventType            String
  roomSid              String?
  roomName             String?
  participantSid       String?
  participantIdentity  String?
  agentCallId          String?
  processingStatus     LiveKitWebhookProcessingStatus @default(RECEIVED)
  errorMessage         String?
  payload              Json
  createdAtFromLiveKit DateTime?
  receivedAt           DateTime                       @default(now())
  processedAt          DateTime?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  agentCall            AgentCall?                     @relation(fields: [agentCallId], references: [id], onDelete: SetNull)

  @@index([eventType, receivedAt])
  @@index([roomSid])
  @@index([roomName])
  @@index([processingStatus, receivedAt])
  @@index([agentCallId])
  @@map("livekit_webhook_event")
}

model AgentCallEvaluationLabel {
  id              String                    @id @default(cuid())
  practiceId      String
  callId          String
  bucket          AgentCallEvaluationBucket
  comment         String?
  createdByUserId String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  call            AgentCall                 @relation(fields: [callId], references: [id], onDelete: Cascade)
  practice        Practice                  @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([callId, bucket])
  @@index([practiceId, bucket])
  @@index([callId])
  @@map("agent_call_evaluation_label")
}

model UsageCostLineItem {
  id          String            @id @default(cuid())
  practiceId  String
  agentCallId String?
  category    UsageCostCategory
  provider    String
  model       String?
  quantity    Float             @default(0)
  unit        String
  costMicros  Int               @default(0)
  occurredAt  DateTime          @default(now())
  metadata    Json?
  createdAt   DateTime          @default(now())
  agentCall   AgentCall?        @relation(fields: [agentCallId], references: [id], onDelete: SetNull)
  practice    Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, occurredAt])
  @@index([agentCallId])
  @@index([category])
  @@map("usage_cost_line_item")
}

model PracticeMembership {
  id            String                          @id @default(cuid())
  practiceId    String
  userId        String
  role          PracticeMembershipRole          @default(OWNER)
  locationScope PracticeMembershipLocationScope @default(ALL)
  isPrimary     Boolean                         @default(true)
  createdAt     DateTime                        @default(now())
  updatedAt     DateTime                        @updatedAt
  locations     PracticeMembershipLocation[]
  practice      Practice                        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user          User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId])
  @@index([practiceId])
  @@index([userId])
  @@map("practice_membership")
}

model PracticeMembershipLocation {
  id           String             @id @default(cuid())
  membershipId String
  locationId   String
  createdAt    DateTime           @default(now())
  location     PracticeLocation   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  membership   PracticeMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, locationId])
  @@index([locationId])
  @@map("practice_membership_location")
}

model PracticeLocation {
  id                       String                       @id @default(cuid())
  practiceId               String
  name                     String
  address                  String?
  phone                    String?
  fax                      String?
  email                    String?
  hoursSummary             String?
  isPrimary                Boolean                      @default(false)
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  agentCalls               AgentCall[]
  agentTasks               AgentTask[]
  callCenterAgentSeats     CallCenterAgentSeat[]
  callCenterMissed         CallCenterMissedCall[]
  callCenterNotes          CallCenterNote[]
  callCenterQueueItems     CallCenterQueueItem[]
  callCenterSessions       CallCenterSession[]
  callCenterVoicemails     CallCenterVoicemail[]
  callCenterQueueLocations CallCenterQueueLocation[]
  callCenterEndpoints      CallCenterEndpoint[]
  insuranceRuleSets        PracticeInsuranceRuleSet[]
  knowledgeDocuments       PracticeKnowledgeDocument[]
  membershipGrants         PracticeMembershipLocation[]
  phoneNumbers             PracticePhoneNumber[]
  practice                 Practice                     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  providers                PracticeProvider[]
  smsConversations         SmsConversation[]

  @@index([practiceId])
  @@map("practice_location")
}

model PracticeProvider {
  id                String            @id @default(cuid())
  practiceId        String
  primaryLocationId String?
  displayName       String
  npi               String?
  specialtySummary  String?
  scheduleSummary   String?
  schedulingNotes   String?
  speechAliases     Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  practice          Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  primaryLocation   PracticeLocation? @relation(fields: [primaryLocationId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([primaryLocationId])
  @@map("practice_provider")
}

model PracticeKnowledgeBase {
  id                        String   @id @default(cuid())
  practiceId                String   @unique
  emergencyNotice           String?
  urgencyScreeningQuestions Json?
  urgencyDisposition        String?
  scopeSummary              String?
  excludedServices          Json?
  commonQuestions           String?
  appointmentPrep           String?
  officePolicies            String?
  afterHoursRules           String?
  phrasingRules             String?
  whatToBring               Json?
  appointmentExpectations   Json?
  operationalNotes          Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  practice                  Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("practice_knowledge_base")
}

model PracticeKnowledgeDocument {
  id           String                              @id @default(cuid())
  practiceId   String
  locationId   String?
  title        String
  slug         String
  documentType KnowledgeDocumentType               @default(KNOWLEDGE_BASE)
  status       KnowledgeDocumentStatus             @default(ACTIVE)
  createdAt    DateTime                            @default(now())
  updatedAt    DateTime                            @updatedAt
  alerts       AdminAlert[]
  location     PracticeLocation?                   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice     Practice                            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  revisions    PracticeKnowledgeDocumentRevision[]

  @@unique([practiceId, slug])
  @@index([practiceId])
  @@index([locationId])
  @@map("practice_knowledge_document")
}

model PracticeKnowledgeDocumentRevision {
  id               String                          @id @default(cuid())
  documentId       String
  markdown         String
  source           KnowledgeDocumentRevisionSource @default(PRACTICE)
  status           KnowledgeDocumentRevisionStatus @default(PENDING_APPROVAL)
  editedByUserId   String?
  reviewedByUserId String?
  reviewNote       String?
  createdAt        DateTime                        @default(now())
  reviewedAt       DateTime?
  publishedAt      DateTime?
  alerts           AdminAlert[]
  document         PracticeKnowledgeDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
  @@index([createdAt])
  @@map("practice_knowledge_document_revision")
}

model PracticeInsuranceRuleSet {
  id         String                          @id @default(cuid())
  practiceId String
  locationId String?
  title      String
  slug       String
  status     InsuranceRuleSetStatus          @default(ACTIVE)
  createdAt  DateTime                        @default(now())
  updatedAt  DateTime                        @updatedAt
  alerts     AdminAlert[]
  location   PracticeLocation?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice   Practice                        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  revisions  PracticeInsuranceRuleRevision[]

  @@unique([practiceId, slug])
  @@index([practiceId])
  @@index([locationId])
  @@map("practice_insurance_rule_set")
}

model PracticeInsuranceRuleRevision {
  id               String                      @id @default(cuid())
  ruleSetId        String
  rules            Json
  source           InsuranceRuleRevisionSource @default(PRACTICE)
  status           InsuranceRuleRevisionStatus @default(PENDING_APPROVAL)
  editedByUserId   String?
  reviewedByUserId String?
  reviewNote       String?
  createdAt        DateTime                    @default(now())
  reviewedAt       DateTime?
  publishedAt      DateTime?
  alerts           AdminAlert[]
  ruleSet          PracticeInsuranceRuleSet    @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@index([ruleSetId])
  @@index([status])
  @@index([createdAt])
  @@map("practice_insurance_rule_revision")
}

model AdminAlert {
  id                      String                             @id @default(cuid())
  practiceId              String
  documentId              String?
  revisionId              String?
  insuranceRuleSetId      String?
  insuranceRuleRevisionId String?
  type                    AdminAlertType
  status                  AdminAlertStatus                   @default(UNREAD)
  message                 String
  createdAt               DateTime                           @default(now())
  updatedAt               DateTime                           @updatedAt
  resolvedAt              DateTime?
  document                PracticeKnowledgeDocument?         @relation(fields: [documentId], references: [id], onDelete: SetNull)
  insuranceRuleRevision   PracticeInsuranceRuleRevision?     @relation(fields: [insuranceRuleRevisionId], references: [id], onDelete: SetNull)
  insuranceRuleSet        PracticeInsuranceRuleSet?          @relation(fields: [insuranceRuleSetId], references: [id], onDelete: SetNull)
  practice                Practice                           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  revision                PracticeKnowledgeDocumentRevision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([documentId])
  @@index([revisionId])
  @@index([insuranceRuleSetId])
  @@index([insuranceRuleRevisionId])
  @@index([status])
  @@index([type])
  @@map("admin_alert")
}

model PracticeInsuranceCrosswalk {
  id            String   @id @default(cuid())
  practiceId    String   @unique
  acceptedPlans String?
  exceptions    String?
  transferRules String?
  planRules     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  practice      Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("practice_insurance_crosswalk")
}

model PracticeWebsiteScan {
  id              String            @id @default(cuid())
  practiceId      String
  sourceUrl       String
  finalUrl        String?
  title           String?
  metaDescription String?
  scanStatus      WebsiteScanStatus
  errorMessage    String?
  extractedData   Json?
  scannedAt       DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  practice        Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, scannedAt])
  @@map("practice_website_scan")
}

model SmsConversation {
  id                 String                @id @default(cuid())
  practiceId         String
  locationId         String?
  practiceNumberId   String
  patientPhoneNumber String
  status             SmsConversationStatus @default(OPEN)
  lastMessageAt      DateTime
  lastInboundAt      DateTime?
  optedOut           Boolean               @default(false)
  optedOutAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  location           PracticeLocation?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  messages           SmsMessage[]
  practice           Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practiceNumber     PracticePhoneNumber   @relation(fields: [practiceNumberId], references: [id], onDelete: Cascade)
  reads              SmsConversationRead[]

  @@unique([practiceNumberId, patientPhoneNumber])
  @@index([practiceId, lastMessageAt(sort: Desc)])
  @@index([locationId, status, lastMessageAt(sort: Desc)])
  @@map("sms_conversation")
}

model SmsMessage {
  id              String              @id @default(cuid())
  conversationId  String
  direction       SmsMessageDirection
  status          SmsMessageStatus
  body            String              @db.Text
  fromNumber      String
  toNumber        String
  telnyxMessageId String?             @unique
  errorCode       String?
  errorDetail     String?
  sentByUserId    String?
  createdAt       DateTime            @default(now())
  deliveredAt     DateTime?
  failedAt        DateTime?
  conversation    SmsConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser      User?               @relation(fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([telnyxMessageId])
  @@map("sms_message")
}

model SmsConversationRead {
  conversationId String
  userId         String
  lastReadAt     DateTime
  conversation   SmsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, lastReadAt])
  @@map("sms_conversation_read")
}

model SmsOptOut {
  id                 String              @id @default(cuid())
  practiceNumberId   String
  patientPhoneNumber String
  source             String
  optedOutAt         DateTime            @default(now())
  practiceNumber     PracticePhoneNumber @relation(fields: [practiceNumberId], references: [id], onDelete: Cascade)

  @@unique([practiceNumberId, patientPhoneNumber])
  @@map("sms_opt_out")
}

model PracticeCallCenterSettings {
  id                      String             @id @default(cuid())
  practiceId              String             @unique
  enabled                 Boolean            @default(false)
  provider                CallCenterProvider @default(TELNYX)
  telnyxConnectionId      String?
  telnyxCredentialId      String?
  inboundPhoneNumber      String?
  outboundCallerNumber    String?
  voicemailGreeting       String             @default("Please leave a message after the beep.")
  voicemailTimeoutSec     Int                @default(30)
  recordingEnabled        Boolean            @default(true)
  defaultOutboundNumberId String?            @unique
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  practice                Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  defaultOutboundNumber   CallCenterNumber?  @relation(fields: [defaultOutboundNumberId], references: [id], onDelete: SetNull)

  @@index([enabled])
  @@index([enabled, inboundPhoneNumber])
  @@index([enabled, outboundCallerNumber])
  @@index([enabled, telnyxConnectionId])
  @@map("practice_call_center_settings")
}

model CallCenterQueue {
  id                String                    @id @default(cuid())
  practiceId        String
  name              String
  enabled           Boolean                   @default(true)
  routingMode       CallCenterRoutingMode     @default(LEGACY)
  ringTimeoutSec    Int                       @default(20)
  maxWaitSec        Int                       @default(30)
  wrapUpSec         Int                       @default(0)
  voicemailEnabled  Boolean                   @default(true)
  voicemailGreeting String                    @default("Please leave a message after the beep.")
  overflowQueueId   String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  practice          Practice                  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  overflowQueue     CallCenterQueue?          @relation("CallCenterQueueOverflow", fields: [overflowQueueId], references: [id], onDelete: SetNull)
  overflowedBy      CallCenterQueue[]         @relation("CallCenterQueueOverflow")
  locations         CallCenterQueueLocation[]
  inboundNumbers    CallCenterNumber[]
  members           CallCenterQueueMember[]
  calls             CallCenterCall[]

  @@unique([practiceId, name])
  @@index([practiceId, enabled])
  @@index([overflowQueueId])
  @@map("call_center_queue")
}

model CallCenterQueueLocation {
  queueId    String
  locationId String
  createdAt  DateTime         @default(now())
  queue      CallCenterQueue  @relation(fields: [queueId], references: [id], onDelete: Cascade)
  location   PracticeLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([queueId, locationId])
  @@index([locationId])
  @@map("call_center_queue_location")
}

model CallCenterNumber {
  id                    String                      @id @default(cuid())
  practiceId            String
  practicePhoneNumberId String                      @unique
  providerNumberId      String?                     @unique
  inboundQueueId        String?
  inboundEnabled        Boolean                     @default(false)
  outboundEnabled       Boolean                     @default(false)
  enabled               Boolean                     @default(true)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  practice              Practice                    @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practicePhoneNumber   PracticePhoneNumber         @relation(fields: [practicePhoneNumberId], references: [id], onDelete: Cascade)
  inboundQueue          CallCenterQueue?            @relation(fields: [inboundQueueId], references: [id], onDelete: SetNull)
  defaultForSettings    PracticeCallCenterSettings?
  calls                 CallCenterCall[]

  @@index([practiceId, enabled])
  @@index([inboundQueueId, inboundEnabled, enabled])
  @@map("call_center_number")
}

model CallCenterQueueMember {
  id        String                    @id @default(cuid())
  queueId   String
  userId    String
  role      CallCenterQueueMemberRole @default(AGENT)
  enabled   Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  queue     CallCenterQueue           @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
  @@index([queueId, role, enabled])
  @@index([userId, enabled])
  @@map("call_center_queue_member")
}

model CallCenterEndpoint {
  id                   String                   @id @default(cuid())
  practiceId           String
  locationId           String?
  label                String
  providerCredentialId String?                  @unique
  sipUsername          String?                  @unique
  enabled              Boolean                  @default(true)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  practice             Practice                 @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  location             PracticeLocation?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  agentSessions        CallCenterAgentSession[]
  callLegs             CallCenterCallLeg[]

  @@unique([practiceId, label])
  @@index([practiceId, enabled])
  @@index([practiceId, locationId, enabled])
  @@index([locationId])
  @@map("call_center_endpoint")
}

model CallCenterAgentSession {
  id               String                         @id @default(cuid())
  practiceId       String
  userId           String
  endpointId       String
  browserSessionId String
  presence         CallCenterAgentPresence        @default(OFFLINE)
  connectionState  CallCenterAgentConnectionState @default(CONNECTING)
  microphoneReady  Boolean                        @default(false)
  audioReady       Boolean                        @default(false)
  currentCallId    String?
  readyAt          DateTime?
  lastHeartbeatAt  DateTime                       @default(now())
  leaseExpiresAt   DateTime
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  practice         Practice                       @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user             User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint         CallCenterEndpoint             @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  currentCall      CallCenterCall?                @relation("CallCenterCurrentCall", fields: [currentCallId], references: [id], onDelete: SetNull)
  callLegs         CallCenterCallLeg[]

  @@unique([endpointId, browserSessionId])
  @@index([practiceId, userId, presence])
  @@index([practiceId, presence, connectionState, lastHeartbeatAt, leaseExpiresAt])
  @@index([userId])
  @@index([currentCallId])
  @@map("call_center_agent_session")
}

model CallCenterCall {
  id                    String                   @id @default(cuid())
  practiceId            String
  queueId               String?
  numberId              String
  direction             CallCenterCallDirection
  status                CallCenterCallStatus     @default(RECEIVED)
  fromPhone             String
  toPhone               String
  callerName            String?
  providerCallSessionId String?                  @unique
  winningLegId          String?                  @unique
  stateVersion          Int                      @default(0)
  receivedAt            DateTime                 @default(now())
  queuedAt              DateTime?
  firstRingAt           DateTime?
  answeredAt            DateTime?
  voicemailStartedAt    DateTime?
  endedAt               DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  practice              Practice                 @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  queue                 CallCenterQueue?         @relation(fields: [queueId], references: [id], onDelete: SetNull)
  number                CallCenterNumber         @relation(fields: [numberId], references: [id], onDelete: Restrict)
  winningLeg            CallCenterCallLeg?       @relation("CallCenterWinningLeg", fields: [winningLegId], references: [id], onDelete: SetNull)
  legs                  CallCenterCallLeg[]      @relation("CallCenterCallLegs")
  activeAgentSessions   CallCenterAgentSession[] @relation("CallCenterCurrentCall")
  tasks                 CallCenterTask[]
  commands              CallCenterCommand[]
  voicemail             CallCenterVoicemail?

  @@index([practiceId, status, receivedAt])
  @@index([practiceId, queueId, status, receivedAt])
  @@index([numberId])
  @@map("call_center_call")
}

model CallCenterCallLeg {
  id                    String                  @id @default(cuid())
  callId                String
  kind                  CallCenterLegKind
  endpointId            String?
  agentSessionId        String?
  providerCallControlId String?                 @unique
  providerCallLegId     String?                 @unique
  providerCallSessionId String?
  status                CallCenterLegStatus     @default(CREATED)
  attemptNumber         Int                     @default(1)
  startedAt             DateTime                @default(now())
  answeredAt            DateTime?
  bridgedAt             DateTime?
  endedAt               DateTime?
  hangupCauseCode       String?
  errorCode             String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  call                  CallCenterCall          @relation("CallCenterCallLegs", fields: [callId], references: [id], onDelete: Cascade)
  endpoint              CallCenterEndpoint?     @relation(fields: [endpointId], references: [id], onDelete: SetNull)
  agentSession          CallCenterAgentSession? @relation(fields: [agentSessionId], references: [id], onDelete: SetNull)
  wonCall               CallCenterCall?         @relation("CallCenterWinningLeg")
  commands              CallCenterCommand[]

  @@index([callId, status])
  @@index([endpointId, status])
  @@index([agentSessionId])
  @@index([providerCallSessionId])
  @@map("call_center_call_leg")
}

model CallCenterTask {
  id                  String               @id @default(cuid())
  practiceId          String
  callId              String?
  sourceEventRevision BigInt
  callerPhone         String?
  kind                CallCenterTaskKind
  status              CallCenterTaskStatus @default(OPEN)
  assignedToUserId    String?
  resolvedByUserId    String?
  resolvedAt          DateTime?
  dedupeKey           String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  practice            Practice             @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  call                CallCenterCall?      @relation(fields: [callId], references: [id], onDelete: Cascade)
  sourceEvent         CallCenterEvent      @relation(fields: [sourceEventRevision], references: [revision], onDelete: Restrict)
  assignedTo          User?                @relation("CallCenterTaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  resolvedBy          User?                @relation("CallCenterTaskResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@unique([practiceId, dedupeKey])
  @@index([practiceId, status, createdAt])
  @@index([callId])
  @@index([sourceEventRevision])
  @@index([assignedToUserId, status])
  @@index([resolvedByUserId])
  @@map("call_center_task")
}

model ProviderWebhookEvent {
  id               String                          @id @default(cuid())
  provider         CallCenterProvider
  providerEventId  String
  eventType        String
  occurredAt       DateTime?
  receivedAt       DateTime                        @default(now())
  processingStatus ProviderWebhookProcessingStatus @default(RECEIVED)
  attemptCount     Int                             @default(0)
  nextAttemptAt    DateTime?
  errorCode        String?
  payload          Json
  processedAt      DateTime?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  @@unique([provider, providerEventId])
  @@index([processingStatus, nextAttemptAt, receivedAt])
  @@index([provider, eventType, receivedAt])
  @@map("provider_webhook_event")
}

model CallCenterCommand {
  id             String                  @id @default(cuid())
  practiceId     String
  callId         String
  legId          String?
  type           CallCenterCommandType
  idempotencyKey String
  status         CallCenterCommandStatus @default(PENDING)
  attemptCount   Int                     @default(0)
  nextAttemptAt  DateTime?
  errorCode      String?
  arguments      Json                    @default("{}")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  practice       Practice                @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  call           CallCenterCall          @relation(fields: [callId], references: [id], onDelete: Cascade)
  leg            CallCenterCallLeg?      @relation(fields: [legId], references: [id], onDelete: SetNull)

  @@unique([practiceId, type, idempotencyKey])
  @@index([status, nextAttemptAt, createdAt])
  @@index([practiceId, callId])
  @@index([legId])
  @@map("call_center_command")
}

model CallCenterEvent {
  revision       BigInt                       @id @default(autoincrement())
  practiceId     String
  aggregateType  CallCenterEventAggregateType
  aggregateId    String
  type           String
  occurredAt     DateTime                     @default(now())
  actorUserId    String?
  idempotencyKey String?
  data           Json                         @default("{}")
  createdAt      DateTime                     @default(now())
  practice       Practice                     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  actor          User?                        @relation("CallCenterEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  sourcedTasks   CallCenterTask[]

  @@unique([practiceId, type, idempotencyKey])
  @@index([practiceId, revision])
  @@index([practiceId, aggregateType, aggregateId, revision])
  @@index([actorUserId])
  @@map("call_center_event")
}

model CallCenterAgentSeat {
