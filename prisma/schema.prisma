model CallCenterSession {
  id                  String                     @id @default(cuid())
  practiceId          String
  locationId          String?
  agentCallId         String?
  provider            CallCenterProvider         @default(TELNYX)
  telnyxCallControlId String?                    @unique
  telnyxCallLegId     String?                    @unique
  telnyxCallSessionId String?
  direction           CallCenterSessionDirection @default(UNKNOWN)
  status              CallCenterSessionStatus    @default(RINGING)
  fromPhone           String?
  toPhone             String?
