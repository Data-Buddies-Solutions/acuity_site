generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  emailVerified        Boolean               @default(false)
  image                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  accounts             Account[]
  callCenterNotes      CallCenterNote[]
  callCenterPresence   CallCenterPresence[]
  memberships          PracticeMembership[]
  sessions             Session[]
  smsConversationReads SmsConversationRead[]
  smsMessages          SmsMessage[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum PracticeMembershipRole {
  OWNER
  ADMIN
  STAFF
}

enum PracticeMembershipLocationScope {
  ALL
  SELECTED
}

enum PracticeOnboardingStatus {
  WEBSITE_PENDING
  BASICS_PENDING
  PROVIDERS_PENDING
  INSURANCE_PENDING
  KNOWLEDGE_PENDING
  READY_TO_LAUNCH
  LIVE
}

enum PracticeType {
  OPHTHALMOLOGY
  OPTOMETRY
  MIXED
  OTHER
}

enum PracticeAgentStatus {
  SETUP
  ACTIVE
  PAUSED
  ERROR
}

enum AgentCallStatus {
  IN_PROGRESS
  COMPLETED
  ESCALATED
  FAILED
  ABANDONED
}

enum AgentCallEvaluationBucket {
  GOLDEN
  BAD
}

enum UsageCostCategory {
  LLM_INPUT
  LLM_CACHED_INPUT
  LLM_OUTPUT
  SPEECH_TO_TEXT
  TEXT_TO_SPEECH
  TELEPHONY
  REVIEW
  OTHER
}

enum CallCenterProvider {
  TELNYX
}

enum CallCenterSessionDirection {
  INBOUND
  OUTBOUND
  INTERNAL
  UNKNOWN
}

enum CallCenterSessionStatus {
  RINGING
  ACTIVE
  COMPLETED
  MISSED
  VOICEMAIL
  FAILED
}

enum CallCenterPresenceStatus {
  AVAILABLE
  BUSY
  OFFLINE
  PAUSED
}

enum CallCenterQueueStatus {
  RINGING
  WAITING
  ASSIGNED
  ACTIVE
  VOICEMAIL
  COMPLETED
  ABANDONED
}

enum CallCenterRingAttemptStatus {
  DIALING
  RINGING
  ANSWERED
  BRIDGED
  CANCELED
  NO_ANSWER
  FAILED
}

enum CallCenterNoteDisposition {
  RESOLVED
  CALLBACK_NEEDED
  FOLLOW_UP_REQUIRED
  WRONG_NUMBER
  OTHER
}

enum WebsiteScanStatus {
  SUCCESS
  FAILED
}

enum KnowledgeDocumentType {
  KNOWLEDGE_BASE
}

enum KnowledgeDocumentStatus {
  ACTIVE
  ARCHIVED
}

enum KnowledgeDocumentRevisionSource {
  ADMIN
  PRACTICE
  IMPORT
}

enum KnowledgeDocumentRevisionStatus {
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

enum InsuranceRuleSetStatus {
  ACTIVE
  ARCHIVED
}

enum InsuranceRuleRevisionSource {
  ADMIN
  PRACTICE
  IMPORT
}

enum InsuranceRuleRevisionStatus {
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

enum AdminAlertType {
  KNOWLEDGE_BASE_EDITED
  INSURANCE_RULES_EDITED
}

enum AdminAlertStatus {
  UNREAD
  REVIEWING
  RESOLVED
}

enum SmsConversationStatus {
  OPEN
  CLOSED
}

enum SmsMessageDirection {
  INBOUND
  OUTBOUND
}

enum SmsMessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  RECEIVED
}

model Practice {
  id                   String                      @id @default(cuid())
  name                 String
  websiteUrl           String?
  brandLogoUrl         String?
  brandLogoAlt         String?
  brandMarkUrl         String?
  brandPrimaryColor    String?
  brandAccentColor     String?
  onboardingStatus     PracticeOnboardingStatus    @default(WEBSITE_PENDING)
  practiceType         PracticeType                @default(OTHER)
  launchReadyAt        DateTime?
  launchedAt           DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  callEvaluationLabels AgentCallEvaluationLabel[]
  agentCalls           AgentCall[]
  agents               PracticeAgent[]
  callCenterAgentSeats CallCenterAgentSeat[]
  callCenterMissed     CallCenterMissedCall[]
  callCenterNotes      CallCenterNote[]
  callCenterQueueItems CallCenterQueueItem[]
  callCenterSessions   CallCenterSession[]
  callCenterSettings   PracticeCallCenterSettings?
  callCenterVoicemails CallCenterVoicemail[]
  costLineItems        UsageCostLineItem[]
  adminAlerts          AdminAlert[]
  insuranceCrosswalk   PracticeInsuranceCrosswalk?
  insuranceRuleSets    PracticeInsuranceRuleSet[]
  knowledgeBase        PracticeKnowledgeBase?
  knowledgeDocuments   PracticeKnowledgeDocument[]
  locations            PracticeLocation[]
  memberships          PracticeMembership[]
  phoneNumbers         PracticePhoneNumber[]
  providers            PracticeProvider[]
  smsConversations     SmsConversation[]
  websiteScans         PracticeWebsiteScan[]

  @@map("practice")
}

model PracticeAgent {
  id              String              @id @default(cuid())
  practiceId      String
  name            String
  status          PracticeAgentStatus @default(SETUP)
  llmModel        String?
  voiceProvider   String?
  voiceName       String?
  configVersion   String?
  lastHeartbeatAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  calls           AgentCall[]
  practice        Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([status])
  @@map("practice_agent")
}

model PracticePhoneNumber {
  id               String            @id @default(cuid())
  practiceId       String
  locationId       String?
  phoneNumber      String            @unique
  label            String?
  isPrimary        Boolean           @default(false)
  smsEnabled       Boolean           @default(false)
  telnyxCampaignId String?
  telnyxSmsStatus  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  location         PracticeLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice         Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  smsConversations SmsConversation[]
  smsOptOuts       SmsOptOut[]

  @@index([practiceId])
  @@index([locationId])
  @@index([smsEnabled])
  @@map("practice_phone_number")
}

model AgentCall {
  id                   String                     @id @default(cuid())
  practiceId           String
  locationId           String?
  agentId              String?
  callId               String                     @unique
  callerPhone          String
  officePhone          String
  status               AgentCallStatus            @default(COMPLETED)
  startedAt            DateTime                   @default(now())
  endedAt              DateTime?
  durationSec          Int                        @default(0)
  transferred          Boolean                    @default(false)
  bookedAppointment    Boolean                    @default(false)
  confirmedAppointment Boolean                    @default(false)
  cancelledAppointment Boolean                    @default(false)
  needsReview          Boolean                    @default(false)
  reviewStatus         String?
  reviewAverageScore   Float?
  reviewResult         Json?
  llmModel             String?
  fallbackUsed         Boolean                    @default(false)
  totalTurns           Int                        @default(0)
  inputTokens          Int                        @default(0)
  outputTokens         Int                        @default(0)
  cachedTokens         Int                        @default(0)
  ttsChars             Int                        @default(0)
  toolCalls            Int                        @default(0)
  toolErrors           Int                        @default(0)
  avgTtft              Float                      @default(0)
  avgTtsttfb           Float                      @default(0)
  cacheHitRate         Float                      @default(0)
  peakContext          Int                        @default(0)
  avgTokensPerSec      Float                      @default(0)
  interruptionCount    Int                        @default(0)
  estimatedCostMicros  Int                        @default(0)
  outcomeSummary       String?
  latencyValues        Json                       @default("{}")
  data                 Json?
  audioData            Bytes?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  agent                PracticeAgent?             @relation(fields: [agentId], references: [id], onDelete: SetNull)
  callCenterMissed     CallCenterMissedCall[]
  callCenterSessions   CallCenterSession[]
  costLineItems        UsageCostLineItem[]
  evaluationLabels     AgentCallEvaluationLabel[]
  location             PracticeLocation?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice             Practice                   @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, startedAt])
  @@index([practiceId, needsReview])
  @@index([practiceId, status])
  @@index([locationId])
  @@index([agentId])
  @@index([callerPhone])
  @@index([officePhone])
  @@map("agent_call")
}

model AgentCallEvaluationLabel {
  id              String                    @id @default(cuid())
  practiceId      String
  callId          String
  bucket          AgentCallEvaluationBucket
  comment         String?
  createdByUserId String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  call            AgentCall                 @relation(fields: [callId], references: [id], onDelete: Cascade)
  practice        Practice                  @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([callId, bucket])
  @@index([practiceId, bucket])
  @@index([callId])
  @@map("agent_call_evaluation_label")
}

model UsageCostLineItem {
  id          String            @id @default(cuid())
  practiceId  String
  agentCallId String?
  category    UsageCostCategory
  provider    String
  model       String?
  quantity    Float             @default(0)
  unit        String
  costMicros  Int               @default(0)
  occurredAt  DateTime          @default(now())
  metadata    Json?
  createdAt   DateTime          @default(now())
  agentCall   AgentCall?        @relation(fields: [agentCallId], references: [id], onDelete: SetNull)
  practice    Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, occurredAt])
  @@index([agentCallId])
  @@index([category])
  @@map("usage_cost_line_item")
}

model PracticeMembership {
  id            String                          @id @default(cuid())
  practiceId    String
  userId        String
  role          PracticeMembershipRole          @default(OWNER)
  locationScope PracticeMembershipLocationScope @default(ALL)
  isPrimary     Boolean                         @default(true)
  createdAt     DateTime                        @default(now())
  updatedAt     DateTime                        @updatedAt
  locations     PracticeMembershipLocation[]
  practice      Practice                        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user          User                            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId])
  @@index([practiceId])
  @@index([userId])
  @@map("practice_membership")
}

model PracticeMembershipLocation {
  id           String             @id @default(cuid())
  membershipId String
  locationId   String
  createdAt    DateTime           @default(now())
  location     PracticeLocation   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  membership   PracticeMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, locationId])
  @@index([locationId])
  @@map("practice_membership_location")
}

model PracticeLocation {
  id                   String                       @id @default(cuid())
  practiceId           String
  name                 String
  address              String?
  phone                String?
  fax                  String?
  email                String?
  hoursSummary         String?
  isPrimary            Boolean                      @default(false)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  agentCalls           AgentCall[]
  callCenterAgentSeats CallCenterAgentSeat[]
  callCenterMissed     CallCenterMissedCall[]
  callCenterNotes      CallCenterNote[]
  callCenterQueueItems CallCenterQueueItem[]
  callCenterSessions   CallCenterSession[]
  callCenterVoicemails CallCenterVoicemail[]
  insuranceRuleSets    PracticeInsuranceRuleSet[]
  knowledgeDocuments   PracticeKnowledgeDocument[]
  membershipGrants     PracticeMembershipLocation[]
  phoneNumbers         PracticePhoneNumber[]
  practice             Practice                     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  providers            PracticeProvider[]
  smsConversations     SmsConversation[]

  @@index([practiceId])
  @@map("practice_location")
}

model PracticeProvider {
  id                String            @id @default(cuid())
  practiceId        String
  primaryLocationId String?
  displayName       String
  npi               String?
  specialtySummary  String?
  scheduleSummary   String?
  schedulingNotes   String?
  speechAliases     Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  practice          Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  primaryLocation   PracticeLocation? @relation(fields: [primaryLocationId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([primaryLocationId])
  @@map("practice_provider")
}

model PracticeKnowledgeBase {
  id                        String   @id @default(cuid())
  practiceId                String   @unique
  emergencyNotice           String?
  urgencyScreeningQuestions Json?
  urgencyDisposition        String?
  scopeSummary              String?
  excludedServices          Json?
  commonQuestions           String?
  appointmentPrep           String?
  officePolicies            String?
  afterHoursRules           String?
  phrasingRules             String?
  whatToBring               Json?
  appointmentExpectations   Json?
  operationalNotes          Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  practice                  Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("practice_knowledge_base")
}

model PracticeKnowledgeDocument {
  id           String                              @id @default(cuid())
  practiceId   String
  locationId   String?
  title        String
  slug         String
  documentType KnowledgeDocumentType               @default(KNOWLEDGE_BASE)
  status       KnowledgeDocumentStatus             @default(ACTIVE)
  createdAt    DateTime                            @default(now())
  updatedAt    DateTime                            @updatedAt
  alerts       AdminAlert[]
  location     PracticeLocation?                   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice     Practice                            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  revisions    PracticeKnowledgeDocumentRevision[]

  @@unique([practiceId, slug])
  @@index([practiceId])
  @@index([locationId])
  @@map("practice_knowledge_document")
}

model PracticeKnowledgeDocumentRevision {
  id               String                          @id @default(cuid())
  documentId       String
  markdown         String
  source           KnowledgeDocumentRevisionSource @default(PRACTICE)
  status           KnowledgeDocumentRevisionStatus @default(PENDING_APPROVAL)
  editedByUserId   String?
  reviewedByUserId String?
  reviewNote       String?
  createdAt        DateTime                        @default(now())
  reviewedAt       DateTime?
  publishedAt      DateTime?
  alerts           AdminAlert[]
  document         PracticeKnowledgeDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
  @@index([createdAt])
  @@map("practice_knowledge_document_revision")
}

model PracticeInsuranceRuleSet {
  id         String                          @id @default(cuid())
  practiceId String
  locationId String?
  title      String
  slug       String
  status     InsuranceRuleSetStatus          @default(ACTIVE)
  createdAt  DateTime                        @default(now())
  updatedAt  DateTime                        @updatedAt
  alerts     AdminAlert[]
  location   PracticeLocation?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice   Practice                        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  revisions  PracticeInsuranceRuleRevision[]

  @@unique([practiceId, slug])
  @@index([practiceId])
  @@index([locationId])
  @@map("practice_insurance_rule_set")
}

model PracticeInsuranceRuleRevision {
  id               String                      @id @default(cuid())
  ruleSetId        String
  rules            Json
  source           InsuranceRuleRevisionSource @default(PRACTICE)
  status           InsuranceRuleRevisionStatus @default(PENDING_APPROVAL)
  editedByUserId   String?
  reviewedByUserId String?
  reviewNote       String?
  createdAt        DateTime                    @default(now())
  reviewedAt       DateTime?
  publishedAt      DateTime?
  alerts           AdminAlert[]
  ruleSet          PracticeInsuranceRuleSet    @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@index([ruleSetId])
  @@index([status])
  @@index([createdAt])
  @@map("practice_insurance_rule_revision")
}

model AdminAlert {
  id                      String                             @id @default(cuid())
  practiceId              String
  documentId              String?
  revisionId              String?
  insuranceRuleSetId      String?
  insuranceRuleRevisionId String?
  type                    AdminAlertType
  status                  AdminAlertStatus                   @default(UNREAD)
  message                 String
  createdAt               DateTime                           @default(now())
  updatedAt               DateTime                           @updatedAt
  resolvedAt              DateTime?
  document                PracticeKnowledgeDocument?         @relation(fields: [documentId], references: [id], onDelete: SetNull)
  insuranceRuleRevision   PracticeInsuranceRuleRevision?     @relation(fields: [insuranceRuleRevisionId], references: [id], onDelete: SetNull)
  insuranceRuleSet        PracticeInsuranceRuleSet?          @relation(fields: [insuranceRuleSetId], references: [id], onDelete: SetNull)
  practice                Practice                           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  revision                PracticeKnowledgeDocumentRevision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([documentId])
  @@index([revisionId])
  @@index([insuranceRuleSetId])
  @@index([insuranceRuleRevisionId])
  @@index([status])
  @@index([type])
  @@map("admin_alert")
}

model PracticeInsuranceCrosswalk {
  id            String   @id @default(cuid())
  practiceId    String   @unique
  acceptedPlans String?
  exceptions    String?
  transferRules String?
  planRules     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  practice      Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("practice_insurance_crosswalk")
}

model PracticeWebsiteScan {
  id              String            @id @default(cuid())
  practiceId      String
  sourceUrl       String
  finalUrl        String?
  title           String?
  metaDescription String?
  scanStatus      WebsiteScanStatus
  errorMessage    String?
  extractedData   Json?
  scannedAt       DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  practice        Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, scannedAt])
  @@map("practice_website_scan")
}

model SmsConversation {
  id                 String                @id @default(cuid())
  practiceId         String
  locationId         String?
  practiceNumberId   String
  patientPhoneNumber String
  status             SmsConversationStatus @default(OPEN)
  lastMessageAt      DateTime
  lastInboundAt      DateTime?
  optedOut           Boolean               @default(false)
  optedOutAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  location           PracticeLocation?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  messages           SmsMessage[]
  practice           Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practiceNumber     PracticePhoneNumber   @relation(fields: [practiceNumberId], references: [id], onDelete: Cascade)
  reads              SmsConversationRead[]

  @@unique([practiceNumberId, patientPhoneNumber])
  @@index([practiceId, lastMessageAt(sort: Desc)])
  @@index([locationId, status, lastMessageAt(sort: Desc)])
  @@map("sms_conversation")
}

model SmsMessage {
  id              String              @id @default(cuid())
  conversationId  String
  direction       SmsMessageDirection
  status          SmsMessageStatus
  body            String              @db.Text
  fromNumber      String
  toNumber        String
  telnyxMessageId String?             @unique
  errorCode       String?
  errorDetail     String?
  sentByUserId    String?
  createdAt       DateTime            @default(now())
  deliveredAt     DateTime?
  failedAt        DateTime?
  conversation    SmsConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser      User?               @relation(fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([telnyxMessageId])
  @@map("sms_message")
}

model SmsConversationRead {
  conversationId String
  userId         String
  lastReadAt     DateTime
  conversation   SmsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, lastReadAt])
  @@map("sms_conversation_read")
}

model SmsOptOut {
  id                 String              @id @default(cuid())
  practiceNumberId   String
  patientPhoneNumber String
  source             String
  optedOutAt         DateTime            @default(now())
  practiceNumber     PracticePhoneNumber @relation(fields: [practiceNumberId], references: [id], onDelete: Cascade)

  @@unique([practiceNumberId, patientPhoneNumber])
  @@map("sms_opt_out")
}

model PracticeCallCenterSettings {
  id                   String             @id @default(cuid())
  practiceId           String             @unique
  enabled              Boolean            @default(false)
  provider             CallCenterProvider @default(TELNYX)
  telnyxConnectionId   String?
  telnyxCredentialId   String?
  inboundPhoneNumber   String?
  outboundCallerNumber String?
  voicemailGreeting    String             @default("Please leave a message after the beep.")
  voicemailTimeoutSec  Int                @default(30)
  recordingEnabled     Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  practice             Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([enabled])
  @@index([enabled, inboundPhoneNumber])
  @@index([enabled, outboundCallerNumber])
  @@index([enabled, telnyxConnectionId])
  @@map("practice_call_center_settings")
}

model CallCenterAgentSeat {
  id                 String                  @id @default(cuid())
  practiceId         String
  locationId         String?
  label              String
  extension          String?
  queueKey           String?
  telnyxCredentialId String?
  sipUsername        String?
  enabled            Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  location           PracticeLocation?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice           Practice                @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  notes              CallCenterNote[]
  presence           CallCenterPresence[]
  ringAttempts       CallCenterRingAttempt[]

  @@index([practiceId])
  @@index([practiceId, locationId])
  @@index([practiceId, locationId, enabled])
  @@index([practiceId, locationId, extension])
  @@index([practiceId, queueKey])
  @@index([practiceId, queueKey, enabled])
  @@index([telnyxCredentialId])
  @@index([sipUsername])
  @@map("call_center_agent_seat")
}

model CallCenterPresence {
  id               String                   @id @default(cuid())
  seatId           String
  userId           String?
  browserSessionId String
  status           CallCenterPresenceStatus @default(OFFLINE)
  lastSeenAt       DateTime                 @default(now())
  currentSessionId String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  seat             CallCenterAgentSeat      @relation(fields: [seatId], references: [id], onDelete: Cascade)
  user             User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([seatId, browserSessionId])
  @@index([seatId])
  @@index([userId])
  @@index([status, lastSeenAt])
  @@index([currentSessionId])
  @@map("call_center_presence")
}

model CallCenterQueueItem {
  id                 String                  @id @default(cuid())
  practiceId         String
  locationId         String?
  callerSessionId    String?                 @unique
  fromPhone          String?
  toPhone            String?
  status             CallCenterQueueStatus   @default(RINGING)
  priority           Int                     @default(0)
  enteredAt          DateTime                @default(now())
  assignedAt         DateTime?
  answeredAt         DateTime?
  endedAt            DateTime?
  voicemailStartedAt DateTime?
  metadata           Json?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  callerSession      CallCenterSession?      @relation(fields: [callerSessionId], references: [id], onDelete: SetNull)
  location           PracticeLocation?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  practice           Practice                @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  ringAttempts       CallCenterRingAttempt[]

  @@index([practiceId, locationId, status, enteredAt])
  @@index([practiceId, status, enteredAt])
  @@index([locationId])
  @@index([callerSessionId])
  @@map("call_center_queue_item")
}

model CallCenterRingAttempt {
  id                  String                      @id @default(cuid())
  queueItemId         String
  seatId              String
  telnyxCallControlId String?                     @unique
  status              CallCenterRingAttemptStatus @default(DIALING)
  startedAt           DateTime                    @default(now())
  answeredAt          DateTime?
  endedAt             DateTime?
  hangupCause         String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  queueItem           CallCenterQueueItem         @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  seat                CallCenterAgentSeat         @relation(fields: [seatId], references: [id], onDelete: Cascade)

  @@unique([queueItemId, seatId])
  @@index([queueItemId])
  @@index([seatId])
  @@index([status])
  @@map("call_center_ring_attempt")
}

model CallCenterSession {
  id                  String                     @id @default(cuid())
  practiceId          String
  locationId          String?
  agentCallId         String?
  provider            CallCenterProvider         @default(TELNYX)
  telnyxCallControlId String?                    @unique
  telnyxCallSessionId String?
  direction           CallCenterSessionDirection @default(UNKNOWN)
  status              CallCenterSessionStatus    @default(RINGING)
  fromPhone           String?
  toPhone             String?
  callerName          String?
  startedAt           DateTime                   @default(now())
  answeredAt          DateTime?
  endedAt             DateTime?
  metadata            Json?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  agentCall           AgentCall?                 @relation(fields: [agentCallId], references: [id], onDelete: SetNull)
  location            PracticeLocation?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  missedCalls         CallCenterMissedCall[]
  notes               CallCenterNote[]
  practice            Practice                   @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  queueItems          CallCenterQueueItem[]
  voicemails          CallCenterVoicemail[]

  @@index([practiceId, startedAt])
  @@index([practiceId, status])
  @@index([locationId])
  @@index([agentCallId])
  @@index([telnyxCallSessionId])
  @@map("call_center_session")
}

model CallCenterMissedCall {
  id          String                @id @default(cuid())
  practiceId  String
  locationId  String?
  sessionId   String?
  agentCallId String?
  fromPhone   String
  callerName  String?
  calledBack  Boolean               @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  agentCall   AgentCall?            @relation(fields: [agentCallId], references: [id], onDelete: SetNull)
  location    PracticeLocation?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  notes       CallCenterNote[]
  practice    Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  session     CallCenterSession?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  voicemails  CallCenterVoicemail[]

  @@index([practiceId, calledBack, createdAt])
  @@index([practiceId, fromPhone])
  @@index([locationId])
  @@index([sessionId])
  @@index([agentCallId])
  @@map("call_center_missed_call")
}

model CallCenterVoicemail {
  id           String                @id @default(cuid())
  practiceId   String
  locationId   String?
  sessionId    String?
  missedCallId String?
  fromPhone    String
  callerName   String?
  recordingUrl String
  recordingId  String                @unique
  durationSec  Int                   @default(0)
  listenedAt   DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  location     PracticeLocation?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  missedCall   CallCenterMissedCall? @relation(fields: [missedCallId], references: [id], onDelete: SetNull)
  notes        CallCenterNote[]
  practice     Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  session      CallCenterSession?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([practiceId, createdAt])
  @@index([practiceId, resolvedAt])
  @@index([practiceId, fromPhone])
  @@index([locationId])
  @@index([sessionId])
  @@index([missedCallId])
  @@map("call_center_voicemail")
}

model CallCenterNote {
  id                   String                    @id @default(cuid())
  practiceId           String
  locationId           String?
  fromPhone            String
  sessionId            String?
  missedCallId         String?
  voicemailId          String?
  stationSeatId        String?
  stationLabelSnapshot String?
  createdByUserId      String?
  createdByLabel       String?
  disposition          CallCenterNoteDisposition
  body                 String?                   @db.Text
  resolvedThread       Boolean                   @default(false)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  createdBy            User?                     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  location             PracticeLocation?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  missedCall           CallCenterMissedCall?     @relation(fields: [missedCallId], references: [id], onDelete: SetNull)
  practice             Practice                  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  session              CallCenterSession?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  stationSeat          CallCenterAgentSeat?      @relation(fields: [stationSeatId], references: [id], onDelete: SetNull)
  voicemail            CallCenterVoicemail?      @relation(fields: [voicemailId], references: [id], onDelete: SetNull)

  @@index([practiceId, fromPhone, createdAt])
  @@index([practiceId, disposition, createdAt])
  @@index([locationId])
  @@index([sessionId])
  @@index([missedCallId])
  @@index([voicemailId])
  @@index([stationSeatId])
  @@index([createdByUserId])
  @@map("call_center_note")
}
